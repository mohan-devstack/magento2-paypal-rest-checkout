<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!--
        Give Client its own Curl instance (shared="false") so our timeout and
        header state never bleeds into other modules that inject the same class.
    -->
    <type name="Mohan\PaypalRest\Model\Client">
        <arguments>
            <argument name="httpClient" xsi:type="object" shared="false">Magento\Framework\HTTP\Client\Curl</argument>
        </arguments>
    </type>
</config>
